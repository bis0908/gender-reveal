# JWT 설정
# 비밀키는 최소 32자 이상의 무작위 문자열을 사용하세요
# 생성 방법: pnpm generate-secret
JWT_SECRET=your-secret-key-here-minimum-32-characters

# 토큰 만료 시간 (s=초, m=분, h=시간, d=일)
JWT_EXPIRATION=7d

# 링크 생성 공통 요청 제한 (원격 연결은 TLS가 적용된 rediss:// 필수)
REDIS_URL=rediss://username:password@host:6379

# Supabase 메트릭 설정
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
SUPABASE_SECRET_KEY=your-server-only-supabase-secret-key

# Next.js 설정
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_BABY_SA_URL=

# 환경 (development, production, test)
NODE_ENV=development
